# Files and directories created by pub
.dart_tool/
.packages

# Conventional directory for build outputs
build/

# Directory created by dartdoc
doc/api/

# Passwords file — kept in VCS for this example so it runs out of the box.
# These are throwaway dev secrets only; never commit real passwords.
# config/passwords.yaml

# Firebase service account key for Firebase auth
config/firebase_service_account_key.json

# Migrations ARE tracked. They are the versioned history of the schema: the same
# migrations must exist on every machine and in every deployment, and `dartway
# create` hands a runnable project to a stranger only because they are here.
# (They used to be ignored, with a note suggesting each machine generate its own.
# That produced divergent migration ids and a template that could not boot.)